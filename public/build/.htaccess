# MIME Fix for Hostinger — serve all assets via PHP to force correct Content-Type
# This bypasses Apache's broken MIME type detection entirely.

RewriteEngine On

# Route ALL asset requests through serve-asset.php (no conditions — unconditional)
RewriteRule ^assets/(.+)$ serve-asset.php?file=$1 [L,QSA]

# Manifest files
RewriteRule ^manifest\.json$ serve-asset.php?file=../manifest.json [L,QSA]
RewriteRule ^manifest\.webmanifest$ serve-asset.php?file=../manifest.webmanifest [L,QSA]
