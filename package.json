{
  "name": "portailrh.pnmls.cd",
  "version": "1.0.0",
  "description": "Gestion Intégrée des Ressources Humaines - Programme National Multisectoriel de Lutte contre le Sida",
  "main": "desktop/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder --win",
    "electron:setup": "powershell -ExecutionPolicy Bypass -File desktop/setup-binaries.ps1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gabriel429/portailrh.pnmls.cd.git"
  },
  "keywords": [],
  "author": "PNMLS",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/gabriel429/portailrh.pnmls.cd/issues"
  },
  "homepage": "https://github.com/gabriel429/portailrh.pnmls.cd#readme",
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@popperjs/core": "^2.11.8",
    "axios": "^1.13.6",
    "bootstrap": "^5.3.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "laravel-vite-plugin": "^3.0.0",
    "vite": "^8.0.1"
  },
  "build": {
    "appId": "cd.pnmls.portailrh",
    "productName": "Portail RH PNMLS",
    "asar": false,
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Portail RH PNMLS"
    },
    "extraResources": [
      {
        "from": "desktop/bin/php",
        "to": "php",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "desktop/bin/mariadb",
        "to": "mariadb",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "desktop/**/*",
      "!desktop/bin/**",
      "public/**/*",
      "!public/storage",
      "app/**/*",
      "bootstrap/**/*",
      "config/**/*",
      "database/**/*",
      "resources/views/**/*",
      "routes/**/*",
      "storage/**/*",
      "vendor/**/*",
      "artisan",
      "composer.json"
    ],
    "directories": {
      "output": "dist-electron"
    }
  }
}
